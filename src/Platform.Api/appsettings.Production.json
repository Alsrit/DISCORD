{
  "ConnectionStrings": {
    "PlatformDb": "Host=prod-db;Port=5432;Database=secure_platform;Username=platform;Password=CHANGE_ME"
  },
  "Security": {
    "LicensePepper": "READ_FROM_ENVIRONMENT"
  },
  "Redis": {
    "Configuration": "prod-redis:6379"
  },
  "Storage": {
    "ReleaseStorageRoot": "/srv/secure-platform/releases",
    "TranslationStorageRoot": "/srv/secure-platform/translations",
    "TranslationTempRoot": "/srv/secure-platform/translations-temp"
  },
  "ServerIdentity": {
    "ServerName": "SecureLicensePlatform API",
    "EnvironmentDisplayName": "Production"
  },
  "UpdateSigning": {
    "PrivateKeyPath": "/run/secrets/update-private.pem",
    "PublicKeyPath": "/run/secrets/update-public.pem"
  },
  "Translation": {
    "QueueName": "translations",
    "MaxPayloadBytes": 2000000,
    "MaxFilesPerRequest": 64,
    "MaxSegmentsPerRequest": 4000,
    "MaxCharactersPerRequest": 120000,
    "QueuePollIntervalSeconds": 5,
    "ProcessingLeaseSeconds": 120,
    "JobTimeoutMinutes": 30,
    "SnapshotRetentionHours": 6,
    "ArtifactRetentionHours": 72,
    "RetryBaseDelaySeconds": 5,
    "MaxRetryAttempts": 3,
    "AnalyzeLimitPerHour": 20,
    "JobCreateLimitPerHour": 10,
    "WorkerBatchCharacters": 3500,
    "ProviderThrottlePerMinute": 120
  },
  "TranslationProviders": {
    "Yandex": {
      "Enabled": true,
      "Endpoint": "https://translate.api.cloud.yandex.net/translate/v2/translate",
      "LanguagesEndpoint": "https://translate.api.cloud.yandex.net/translate/v2/languages",
      "FolderId": "READ_FROM_ENVIRONMENT",
      "ApiKey": "",
      "ApiKeyEnvVar": "YANDEX_TRANSLATE_API_KEY",
      "TimeoutSeconds": 30,
      "MaxBatchCharacters": 4000,
      "FailureThreshold": 3,
      "CircuitBreakSeconds": 60
    }
  },
  "Seed": {
    "AdminPassword": "READ_FROM_ENVIRONMENT"
  }
}
