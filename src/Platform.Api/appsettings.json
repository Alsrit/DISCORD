{
  "ConnectionStrings": {
    "PlatformDb": "Host=localhost;Port=5432;Database=secure_platform;Username=postgres;Password=postgres"
  },
  "Security": {
    "LicensePepper": "CHANGE_ME_DEV_PEPPER",
    "AccessTokenLifetimeMinutes": 120,
    "RefreshTokenLifetimeDays": 30,
    "ActivationLimitPerHour": 10,
    "RefreshLimitPerHour": 120,
    "TelemetryLimitPerMinute": 200,
    "DeviceOfflineThresholdMinutes": 15
  },
  "Redis": {
    "Enabled": true,
    "Configuration": "localhost:6379"
  },
  "Storage": {
    "ReleaseStorageRoot": "storage/releases",
    "TranslationStorageRoot": "storage/translations",
    "TranslationTempRoot": "storage/translations-temp"
  },
  "ServerIdentity": {
    "ServerName": "SecureLicensePlatform API",
    "EnvironmentDisplayName": "Development"
  },
  "UpdateSigning": {
    "PrivateKeyPath": "deploy/keys/update-private.pem",
    "PublicKeyPath": "deploy/keys/update-public.pem"
  },
  "Translation": {
    "QueueName": "translations",
    "MaxPayloadBytes": 2000000,
    "MaxFilesPerRequest": 64,
    "MaxSegmentsPerRequest": 4000,
    "MaxCharactersPerRequest": 120000,
    "QueuePollIntervalSeconds": 5,
    "ProcessingLeaseSeconds": 120,
    "JobTimeoutMinutes": 30,
    "SnapshotRetentionHours": 6,
    "ArtifactRetentionHours": 72,
    "RetryBaseDelaySeconds": 5,
    "MaxRetryAttempts": 3,
    "AnalyzeLimitPerHour": 20,
    "JobCreateLimitPerHour": 10,
    "WorkerBatchCharacters": 3500,
    "ProviderThrottlePerMinute": 120
  },
  "TranslationProviders": {
    "Yandex": {
      "Enabled": false,
      "Endpoint": "https://translate.api.cloud.yandex.net/translate/v2/translate",
      "LanguagesEndpoint": "https://translate.api.cloud.yandex.net/translate/v2/languages",
      "FolderId": "",
      "ApiKey": "",
      "ApiKeyEnvVar": "YANDEX_TRANSLATE_API_KEY",
      "TimeoutSeconds": 30,
      "MaxBatchCharacters": 4000,
      "FailureThreshold": 3,
      "CircuitBreakSeconds": 60
    }
  },
  "Seed": {
    "AdminUserName": "admin",
    "AdminDisplayName": "Главный администратор",
    "AdminEmail": "admin@example.com",
    "AdminPassword": "ChangeThisPassword!",
    "DemoLicenses": [
      {
        "CustomerName": "Тестовый клиент",
        "CustomerEmail": "demo@example.com",
        "RawLicenseKey": "SLP-DEMO-0001-0001-0001",
        "Type": "Subscription",
        "MaxDevices": 2,
        "OfflineGracePeriodHours": 72,
        "UpdateChannel": "Stable",
        "ExpiresUtc": "2027-12-31T23:59:59+00:00"
      },
      {
        "CustomerName": "Внутренняя команда",
        "CustomerEmail": "internal@example.com",
        "RawLicenseKey": "SLP-INTERNAL-0001-0001",
        "Type": "Perpetual",
        "MaxDevices": 10,
        "OfflineGracePeriodHours": 24,
        "UpdateChannel": "Internal"
      }
    ]
  }
}
