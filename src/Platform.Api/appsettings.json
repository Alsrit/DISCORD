{
  "ConnectionStrings": {
    "PlatformDb": "Host=localhost;Port=5432;Database=secure_platform;Username=postgres;Password=postgres"
  },
  "Security": {
    "LicensePepper": "CHANGE_ME_DEV_PEPPER",
    "AccessTokenLifetimeMinutes": 120,
    "RefreshTokenLifetimeDays": 30,
    "ActivationLimitPerHour": 10,
    "RefreshLimitPerHour": 120,
    "TelemetryLimitPerMinute": 200,
    "DeviceOfflineThresholdMinutes": 15
  },
  "Redis": {
    "Enabled": true,
    "Configuration": "localhost:6379"
  },
  "Storage": {
    "ReleaseStorageRoot": "storage/releases"
  },
  "ServerIdentity": {
    "ServerName": "SecureLicensePlatform API",
    "EnvironmentDisplayName": "Development"
  },
  "UpdateSigning": {
    "PrivateKeyPath": "deploy/keys/update-private.pem",
    "PublicKeyPath": "deploy/keys/update-public.pem"
  },
  "Seed": {
    "AdminUserName": "admin",
    "AdminDisplayName": "Главный администратор",
    "AdminEmail": "admin@example.com",
    "AdminPassword": "ChangeThisPassword!",
    "DemoLicenses": [
      {
        "CustomerName": "Тестовый клиент",
        "CustomerEmail": "demo@example.com",
        "RawLicenseKey": "SLP-DEMO-0001-0001-0001",
        "Type": "Subscription",
        "MaxDevices": 2,
        "OfflineGracePeriodHours": 72,
        "UpdateChannel": "Stable",
        "ExpiresUtc": "2027-12-31T23:59:59+00:00"
      },
      {
        "CustomerName": "Внутренняя команда",
        "CustomerEmail": "internal@example.com",
        "RawLicenseKey": "SLP-INTERNAL-0001-0001",
        "Type": "Perpetual",
        "MaxDevices": 10,
        "OfflineGracePeriodHours": 24,
        "UpdateChannel": "Internal"
      }
    ]
  }
}
