@page
@model Platform.Admin.Pages.SecurityModel
@{
    ViewData["Title"] = "Безопасность";
}

<header class="page-header">
    <div>
        <p class="eyebrow">Аудит и инциденты</p>
        <h2 class="page-title">Журнал безопасности</h2>
        <p class="page-subtitle">Подозрительные активации, refresh-аномалии и административный аудит.</p>
    </div>
</header>

<section class="row g-4">
    <div class="col-lg-6">
        <div class="panel">
            <h3>Инциденты</h3>
            <div class="table-shell mt-3">
                <table class="table table-dark table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Время</th>
                            <th>Тип</th>
                            <th>Описание</th>
                            <th>IP</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Incidents)
                    {
                        <tr>
                            <td>@item.OccurredUtc.ToLocalTime().ToString("g")</td>
                            <td>@item.Type</td>
                            <td>@item.Description</td>
                            <td>@item.IpAddress</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="panel">
            <h3>Аудит действий</h3>
            <div class="table-shell mt-3">
                <table class="table table-dark table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Время</th>
                            <th>Категория</th>
                            <th>Событие</th>
                            <th>Сообщение</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.AuditEvents)
                    {
                        <tr>
                            <td>@item.CreatedUtc.ToLocalTime().ToString("g")</td>
                            <td>@item.Category</td>
                            <td>@item.EventType</td>
                            <td>@item.Message</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
