@page
@model Platform.Admin.Pages.LicensesModel
@{
    ViewData["Title"] = "Лицензии";
}

<header class="page-header">
    <div>
        <p class="eyebrow">Управление доступом</p>
        <h2 class="page-title">Лицензии</h2>
        <p class="page-subtitle">Создание, продление и отзыв лицензий с контролем количества устройств.</p>
    </div>
</header>

<section class="row g-4 mb-4">
    <div class="col-lg-4">
        <article class="panel">
            <h3>Новая лицензия</h3>
            <form method="post" asp-page-handler="Create" class="mt-3">
                <div class="mb-3">
                    <label asp-for="CreateRequest.CustomerName" class="form-label">Клиент</label>
                    <input asp-for="CreateRequest.CustomerName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="CreateRequest.CustomerEmail" class="form-label">Email</label>
                    <input asp-for="CreateRequest.CustomerEmail" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="CreateRequest.Type" class="form-label">Тип</label>
                    <select asp-for="CreateRequest.Type" class="form-select" asp-items="Model.LicenseTypeOptions"></select>
                </div>
                <div class="mb-3">
                    <label asp-for="CreateRequest.UpdateChannel" class="form-label">Канал обновлений</label>
                    <select asp-for="CreateRequest.UpdateChannel" class="form-select" asp-items="Model.ChannelOptions"></select>
                </div>
                <div class="row g-3">
                    <div class="col-6">
                        <label asp-for="CreateRequest.MaxDevices" class="form-label">Устройств</label>
                        <input asp-for="CreateRequest.MaxDevices" class="form-control" />
                    </div>
                    <div class="col-6">
                        <label asp-for="CreateRequest.OfflineGracePeriodHours" class="form-label">Grace, ч</label>
                        <input asp-for="CreateRequest.OfflineGracePeriodHours" class="form-control" />
                    </div>
                </div>
                <div class="mt-3 mb-3">
                    <label asp-for="CreateRequest.ExpiresUtc" class="form-label">Срок действия</label>
                    <input asp-for="CreateRequest.ExpiresUtc" class="form-control" type="datetime-local" />
                </div>
                <div class="mb-3">
                    <label asp-for="CreateRequest.Notes" class="form-label">Комментарий</label>
                    <textarea asp-for="CreateRequest.Notes" class="form-control" rows="3"></textarea>
                </div>
                <button type="submit" class="btn btn-primary w-100">Создать лицензию</button>
            </form>
        </article>
    </div>
    <div class="col-lg-8">
        <div class="table-shell">
            <table class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>Ключ</th>
                        <th>Клиент</th>
                        <th>Статус</th>
                        <th>Срок</th>
                        <th>Устройства</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Licenses)
                {
                    <tr>
                        <td>@item.MaskedKey</td>
                        <td>
                            <strong>@item.CustomerName</strong><br />
                            <span class="text-secondary">@item.CustomerEmail</span>
                        </td>
                        <td>@item.Status</td>
                        <td>@(item.ExpiresUtc?.ToLocalTime().ToString("g") ?? "Бессрочно")</td>
                        <td>@item.ActiveDevices / @item.MaxDevices</td>
                        <td>
                            <form method="post" asp-page-handler="Extend" class="d-flex gap-2 mb-2">
                                <input type="hidden" name="LicenseId" value="@item.Id" />
                                <input type="datetime-local" name="NewExpiryUtc" class="form-control form-control-sm" />
                                <button type="submit" class="btn btn-sm btn-warning">Продлить</button>
                            </form>
                            <form method="post" asp-page-handler="Revoke" class="d-flex gap-2">
                                <input type="hidden" name="LicenseId" value="@item.Id" />
                                <input type="text" name="Reason" class="form-control form-control-sm" placeholder="Причина отзыва" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Отозвать</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</section>
