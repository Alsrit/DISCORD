<Window x:Class="Platform.Client.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Secure License Platform"
        Width="1380"
        Height="860"
        MinWidth="1180"
        MinHeight="760"
        Background="#050910"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelSecondaryBrush" Color="#0B1320" />
        <SolidColorBrush x:Key="StrokeBrush" Color="#24324A" />
        <SolidColorBrush x:Key="TextBrush" Color="#F3F6FB" />
        <SolidColorBrush x:Key="MutedBrush" Color="#8FA3BF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#49D2C4" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#162234" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="#101828" />
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0B1320" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#050910" Offset="0" />
                <GradientStop Color="#0A1321" Offset="0.45" />
                <GradientStop Color="#07101C" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Visibility="{Binding IsActivated, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.Background>
                <RadialGradientBrush GradientOrigin="0.1,0.1" Center="0.2,0.2" RadiusX="0.8" RadiusY="0.8">
                    <GradientStop Color="#153342" Offset="0" />
                    <GradientStop Color="#07101C" Offset="0.7" />
                </RadialGradientBrush>
            </Grid.Background>

            <Border Width="560"
                    Padding="36"
                    CornerRadius="28"
                    Background="#0D1625"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Первый запуск" Foreground="{StaticResource AccentBrush}" FontSize="15" />
                    <TextBlock Text="Активация лицензии" FontSize="34" FontWeight="Bold" Margin="0,8,0,12" />
                    <TextBlock Text="Введите лицензионный ключ и выполните безопасную онлайн-активацию." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />

                    <TextBlock Text="Лицензионный ключ" Margin="0,28,0,10" Foreground="{StaticResource MutedBrush}" />
                    <TextBox Text="{Binding ActivationKey, UpdateSourceTrigger=PropertyChanged}" Height="44" FontSize="18" />

                    <Button Content="Активировать" Command="{Binding ActivateCommand}" Height="46" Margin="0,24,0,0" />
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,18,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Visibility="{Binding IsActivated, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#08111C" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,1,0">
                <DockPanel Margin="24">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Secure License Platform" Foreground="{StaticResource AccentBrush}" FontSize="14" />
                        <TextBlock Text="Клиент лицензирования" FontSize="28" FontWeight="Bold" Margin="0,8,0,6" />
                        <TextBlock Text="Статус лицензии, диагностика, безопасные обновления и журнал действий." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top" Margin="0,36,0,0">
                        <Button Style="{StaticResource NavButtonStyle}" Content="Главная" Command="{Binding NavigateCommand}" CommandParameter="Dashboard" />
                        <Button Style="{StaticResource NavButtonStyle}" Content="Перевод модов" Command="{Binding NavigateCommand}" CommandParameter="ModTranslation" />
                        <Button Style="{StaticResource NavButtonStyle}" Content="Логи" Command="{Binding NavigateCommand}" CommandParameter="Logs" />
                        <Button Style="{StaticResource NavButtonStyle}" Content="Настройки" Command="{Binding NavigateCommand}" CommandParameter="Settings" />
                        <Button Style="{StaticResource NavButtonStyle}" Content="О программе" Command="{Binding NavigateCommand}" CommandParameter="About" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom">
                        <Border Background="#101828" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Текущий статус" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding LicenseStatus}" FontSize="24" FontWeight="Bold" Margin="0,6,0,4" />
                                <TextBlock Text="{Binding UpdateStatusText}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="30">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                        <StackPanel Width="760">
                            <TextBlock Text="Управление клиентом" Foreground="{StaticResource AccentBrush}" FontSize="14" />
                            <TextBlock Text="{Binding CurrentSectionTitle}" FontSize="34" FontWeight="Bold" Margin="0,8,0,4" />
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Синхронизировать" Command="{Binding SyncCommand}" Width="170" Margin="12,0,0,10" />
                            <Button Content="Проверить обновления" Command="{Binding CheckUpdatesCommand}" Width="210" Margin="12,0,0,10" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Visibility="{Binding CurrentSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Dashboard}">
                        <WrapPanel Margin="0,24,0,0">
                            <Border Style="{StaticResource SectionCardStyle}" Width="260">
                                <StackPanel>
                                    <TextBlock Text="Лицензия" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding LicenseStatus}" FontSize="26" FontWeight="Bold" Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding LicenseType}" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SectionCardStyle}" Width="260">
                                <StackPanel>
                                    <TextBlock Text="Срок действия" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding ExpiryText}" FontSize="24" FontWeight="Bold" Margin="0,8,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SectionCardStyle}" Width="260">
                                <StackPanel>
                                    <TextBlock Text="Подключение" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding ServerConnectionText}" FontSize="24" FontWeight="Bold" Margin="0,8,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SectionCardStyle}" Width="260">
                                <StackPanel>
                                    <TextBlock Text="Обновления" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding PendingUpdateVersion}" FontSize="24" FontWeight="Bold" Margin="0,8,0,0" />
                                    <Button Content="Установить обновление" Command="{Binding InstallUpdateCommand}" Margin="0,16,0,0" Visibility="{Binding HasPendingUpdate, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Text="Клиент и лицензия" FontSize="24" FontWeight="Bold" />
                                    <TextBlock Text="{Binding CustomerText}" Margin="0,16,0,6" />
                                    <TextBlock Text="{Binding DevicesText}" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding LastSyncText}" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Состояние сервера" FontSize="24" FontWeight="Bold" />
                                    <TextBlock Text="{Binding ServerHealthText}" Margin="0,16,0,6" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding UpdateStatusText}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Visibility="{Binding CurrentSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=ModTranslation}">
                        <!-- translation-section -->
                        <Grid Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock Text="Каталог модов" FontSize="24" FontWeight="Bold" DockPanel.Dock="Left" />
                                        <Button Content="Обновить список"
                                                Command="{Binding ModTranslation.ScanModsCommand}"
                                                Width="150"
                                                Margin="12,0,0,10"
                                                DockPanel.Dock="Right" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding ModTranslation.CatalogStatus}"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,14" />
                                    <Button Content="Открыть папку выбранного мода"
                                            Command="{Binding ModTranslation.OpenSelectedModFolderCommand}"
                                            Margin="0,0,0,12" />
                                    <ListBox ItemsSource="{Binding ModTranslation.AvailableMods}"
                                             SelectedItem="{Binding ModTranslation.SelectedMod}"
                                             Height="620">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10"
                                                        Padding="14"
                                                        CornerRadius="18"
                                                        Background="#091321"
                                                        BorderBrush="{StaticResource StrokeBrush}"
                                                        BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" />
                                                        <TextBlock Text="{Binding SourceLabel}" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding SupportedVersion, StringFormat=Поддерживаемая версия: {0}}" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" />
                                                        <TextBlock Text="{Binding LocalizationFiles.Count, StringFormat=Локализационных файлов: {0}}" Foreground="{StaticResource MutedBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource SectionCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="0.9*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,24,0">
                                            <TextBlock Text="Выбранный мод" FontSize="24" FontWeight="Bold" />
                                            <TextBlock Text="{Binding ModTranslation.SelectedModSummary}"
                                                       Margin="0,16,0,0"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="Квота" Foreground="{StaticResource AccentBrush}" Margin="0,22,0,4" />
                                            <TextBlock Text="{Binding ModTranslation.QuotaSummary}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                            <TextBlock Text="Активные словари" Foreground="{StaticResource AccentBrush}" Margin="0,18,0,4" />
                                            <TextBlock Text="{Binding ModTranslation.GlossarySummary}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Параметры перевода" FontSize="24" FontWeight="Bold" />

                                            <TextBlock Text="Исходный язык" Margin="0,16,0,8" Foreground="{StaticResource MutedBrush}" />
                                            <ComboBox ItemsSource="{Binding ModTranslation.AvailableLanguages}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Code"
                                                      SelectedValue="{Binding ModTranslation.SourceLanguage}" />

                                            <TextBlock Text="Целевой язык" Margin="0,16,0,8" Foreground="{StaticResource MutedBrush}" />
                                            <ComboBox ItemsSource="{Binding ModTranslation.AvailableLanguages}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Code"
                                                      SelectedValue="{Binding ModTranslation.TargetLanguage}" />

                                            <TextBlock Text="Имя сабмода" Margin="0,16,0,8" Foreground="{StaticResource MutedBrush}" />
                                            <TextBox Text="{Binding ModTranslation.RequestedSubmodName, UpdateSourceTrigger=PropertyChanged}" />

                                            <CheckBox IsChecked="{Binding ModTranslation.DryRunBuild}"
                                                      Content="Сначала dry-run без записи на диск"
                                                      Margin="0,16,0,0" />
                                            <CheckBox IsChecked="{Binding ModTranslation.CreateBackup}"
                                                      Content="Создавать backup при повторной сборке"
                                                      Margin="0,8,0,0" />

                                            <WrapPanel Margin="0,18,0,0">
                                                <Button Content="Анализировать мод"
                                                        Command="{Binding ModTranslation.AnalyzeCommand}"
                                                        Width="180" />
                                                <Button Content="Запустить перевод"
                                                        Command="{Binding ModTranslation.StartTranslationCommand}"
                                                        Width="180"
                                                        Margin="12,0,0,10" />
                                            </WrapPanel>
                                            <WrapPanel>
                                                <Button Content="Обновить статус"
                                                        Command="{Binding ModTranslation.RefreshJobCommand}"
                                                        Width="180" />
                                                <Button Content="Отменить задание"
                                                        Command="{Binding ModTranslation.CancelJobCommand}"
                                                        Width="180"
                                                        Margin="12,0,0,10" />
                                            </WrapPanel>
                                            <WrapPanel>
                                                <Button Content="Скачать результат"
                                                        Command="{Binding ModTranslation.DownloadResultCommand}"
                                                        Width="180" />
                                                <Button Content="Собрать сабмод"
                                                        Command="{Binding ModTranslation.BuildSubmodCommand}"
                                                        Width="180"
                                                        Margin="12,0,0,10" />
                                            </WrapPanel>
                                            <Button Content="Открыть папку сабмода"
                                                    Command="{Binding ModTranslation.OpenOutputFolderCommand}"
                                                    Width="220" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Найденные localisation-файлы" FontSize="24" FontWeight="Bold" />
                                        <ListView ItemsSource="{Binding ModTranslation.SelectedLocalizationFiles}" Margin="0,18,0,0" Height="220">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="Файл" DisplayMemberBinding="{Binding RelativePath}" Width="350" />
                                                    <GridViewColumn Header="Header" DisplayMemberBinding="{Binding HeaderKey}" Width="110" />
                                                    <GridViewColumn Header="Сегменты" DisplayMemberBinding="{Binding SegmentCount}" Width="90" />
                                                    <GridViewColumn Header="Символы" DisplayMemberBinding="{Binding CharacterCount}" Width="90" />
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </StackPanel>
                                </Border>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Ход задания" FontSize="24" FontWeight="Bold" />
                                            <TextBlock Text="{Binding ModTranslation.JobStatusLabel}" Margin="0,16,0,8" />
                                            <ProgressBar Height="18" Minimum="0" Maximum="100" Value="{Binding ModTranslation.JobProgressPercent}" />
                                            <TextBlock Text="{Binding ModTranslation.TranslationStatus}"
                                                       Margin="0,14,0,0"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       TextWrapping="Wrap" />

                                            <TextBlock Text="Файлы результата" Foreground="{StaticResource AccentBrush}" Margin="0,20,0,8" />
                                            <ListView ItemsSource="{Binding ModTranslation.ResultFiles}" Height="220">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="Файл" DisplayMemberBinding="{Binding RelativePath}" Width="300" />
                                                        <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding Status}" Width="100" />
                                                        <GridViewColumn Header="Сегменты" DisplayMemberBinding="{Binding SegmentCount}" Width="90" />
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Сборка сабмода" FontSize="24" FontWeight="Bold" />
                                            <TextBlock Text="{Binding ModTranslation.BuildPreviewText}"
                                                       Margin="0,16,0,0"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ModTranslation.BuildStatus}"
                                                       Margin="0,18,0,0"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ModTranslation.OutputFolderPath}"
                                                       Margin="0,12,0,0"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ModTranslation.BackupPath}"
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Технические сообщения" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="{Binding DiagnosticsText}" Margin="0,16,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Visibility="{Binding CurrentSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Logs}">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <DockPanel>
                                <TextBlock Text="Последние действия клиента" FontSize="24" FontWeight="Bold" DockPanel.Dock="Top" />
                                <Button Content="Обновить список" Command="{Binding RefreshLogsCommand}" Width="180" HorizontalAlignment="Right" DockPanel.Dock="Top" />
                                <ListView ItemsSource="{Binding Logs}" Margin="0,18,0,0" Background="Transparent" BorderThickness="0">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Время" DisplayMemberBinding="{Binding Timestamp}" Width="170" />
                                            <GridViewColumn Header="Уровень" DisplayMemberBinding="{Binding Level}" Width="110" />
                                            <GridViewColumn Header="Категория" DisplayMemberBinding="{Binding Category}" Width="140" />
                                            <GridViewColumn Header="Сообщение" DisplayMemberBinding="{Binding Message}" Width="540" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </DockPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Visibility="{Binding CurrentSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Settings}">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Настройки" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="URL сервера" Margin="0,18,0,8" Foreground="{StaticResource MutedBrush}" />
                                <TextBox Text="{Binding ServerBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Путь к пользовательским данным Stellaris" Margin="0,18,0,8" Foreground="{StaticResource MutedBrush}" />
                                <TextBox Text="{Binding StellarisUserDataPath, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="Корневой каталог Steam" Margin="0,18,0,8" Foreground="{StaticResource MutedBrush}" />
                                <TextBox Text="{Binding SteamRootPath, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="Каталог вывода сабмодов" Margin="0,18,0,8" Foreground="{StaticResource MutedBrush}" />
                                <TextBox Text="{Binding SubmodOutputRoot, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox IsChecked="{Binding AutoCheckUpdates}" Content="Автоматически проверять обновления" Margin="0,16,0,0" />
                                <CheckBox IsChecked="{Binding EnableAutostart}" Content="Запускать вместе с Windows" Margin="0,8,0,0" />
                                <CheckBox IsChecked="{Binding RequireCertificatePinning}" Content="Требовать pinning сертификата" Margin="0,8,0,0" />

                                <TextBlock Text="SPKI SHA-256 pins (по одному в строке)" Margin="0,20,0,8" Foreground="{StaticResource MutedBrush}" />
                                <TextBox Text="{Binding PinnedCertificatesText}" Height="110" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" />

                                <TextBlock Text="Путь к публичному ключу подписи обновлений" Margin="0,20,0,8" Foreground="{StaticResource MutedBrush}" />
                                <TextBox Text="{Binding UpdatePublicKeyPath, UpdateSourceTrigger=PropertyChanged}" />

                                <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                                    <Button Content="Сохранить настройки" Command="{Binding SaveSettingsCommand}" Width="220" />
                                    <Button Content="Сбросить локальную сессию" Command="{Binding ResetSessionCommand}" Width="220" Margin="14,0,0,10" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Visibility="{Binding CurrentSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=About}">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="О программе" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="{Binding AboutText}" Margin="0,16,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
